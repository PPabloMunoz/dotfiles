# My ZSH configuration
export TERM=xterm-256color
export XDG_CONFIG_HOME=$HOME/.config

# ====== General ======
ZSH_CFG="$XDG_CONFIG_HOME/zsh"
DISABLE_AUTO_TITLE="true"
COMPLETION_WAITING_DOTS="true"
DISABLE_UNTRACKED_FILES_DIRTY="true"
HISTFILE=$HOME/.zsh_history
HISTSIZE=1000000
SAVEHIST=1000000
export ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=8'

setopt SHARE_HISTORY          # Share history between sessions
setopt APPEND_HISTORY         # Append to history file
setopt INC_APPEND_HISTORY     # Write to history file immediately
setopt HIST_IGNORE_ALL_DUPS   # Don't store duplicates
setopt HIST_REDUCE_BLANKS     # Remove unnecessary blanks
setopt HIST_IGNORE_SPACE      # Don't record commands starting with a space
setopt autocd extendedglob nomatch menucomplete interactive_comments
unsetopt correct_all BEEP
autoload -Uz colors && colors
bindkey -e

# ====== Exports ======
# Standard paths
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:$HOME/.local/bin:$PATH"
# Go
export PATH="$PATH:/usr/local/go/bin:$HOME/go/bin"
# Bun
export PATH="$HOME/.bun/bin:$PATH"
# Tools/SDKs
export PATH="/opt/homebrew/opt/openjdk@21/bin:/opt/homebrew/opt/libpq/bin:$PATH"
export PATH="$HOME/.jenv/bin:$PATH"

export CARAPACE_BRIDGES='zsh'
export NODE_ENV=development
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
export EDITOR="nvim"

# ====== Functions ======
eval_if_exists() {
    if command -v "$1" >/dev/null 2>&1; then
        eval "$2"
    fi
}

zsh_add_plugin() {
  local PLUGIN_NAME=$(echo $1 | cut -d "/" -f 2)
  local PLUGIN_DIR="$XDG_CONFIG_HOME/zsh/plugins/$PLUGIN_NAME"

  if [ ! -d "$PLUGIN_DIR" ]; then
    git clone "https://github.com/$1.git" "$PLUGIN_DIR"
  fi

  for file in "$PLUGIN_DIR/$PLUGIN_NAME.plugin.zsh" "$PLUGIN_DIR/$PLUGIN_NAME.zsh"; do
    [ -f "$file" ] && source "$file" && break
  done
}

# ====== Completions ======
autoload -Uz compinit
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'
zstyle ':completion:*' format $'\e[2;37mCompleting %d\e[m'
zstyle ':completion:*:git:*' group-order 'main commands' 'alias commands' 'external commands'

_comp_options+=(globdots)
compinit

eval_if_exists "zoxide" "$(zoxide init zsh)"
eval_if_exists "fnm" "$(fnm env)"
eval_if_exists "fzf" "$(fzf --zsh)"
eval_if_exists "jenv" "$(jenv init -)"

[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"

# ====== Plugins ======
zsh_add_plugin "zsh-users/zsh-autosuggestions"
zsh_add_plugin "zsh-users/zsh-syntax-highlighting"
zsh_add_plugin "michaelAquilina/zsh-you-should-use"

# ====== Aliases ======
# Navigation & LS
alias ls="eza -s type"
alias ll="eza --color=always --icons --no-time --git --long"
alias la="eza --color=always --icons --no-time --git --long --all"
alias cd="z"

# Tools
alias cat="bat --paging=never --wrap=never --style=plain"
alias lg="lazygit -ucd ~/.config/lazygit/"
alias vim="nvim"
alias oc="opencode"

# ZSH
alias zsh:reload="source $HOME/.zshrc"
alias zsh:edit="nvim $HOME/.zshrc"

# Tmux
alias t="tmux"
alias ta="t a"
alias tls="t ls"
alias tn="t new -t"

# Git
alias gl='git pull'
alias gp='git push'
alias gs='git status'
alias gss='git status -s'
alias ga='git add'
alias gaa='git add --all'
alias gc='git commit -m'
alias gdiff='git diff'

# Init tools
eval_if_exists "carapace" "source <(carapace _carapace)"
eval_if_exists "starship" "$(starship init zsh)"
